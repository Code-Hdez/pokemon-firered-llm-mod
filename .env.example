# FireRed LLM — Environment Variables

# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by python-dotenv when
# running the LLM Inject mode (option 4).

# LLM API Key (required for LLM Inject mode)
# Provide at least one. GEMINI_API_KEY is checked first.
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# IPC / Bridge settings (all optional)
# MGBA_HOST=127.0.0.1
# MGBA_PORT=35600
# MGBA_TIMEOUT=10.0
# MGBA_LOG_LEVEL=INFO
# MGBA_MAX_MSG_SIZE=8192
# MGBA_MAX_INJECT=256
# MGBA_RX_BUF_LIMIT=65536
